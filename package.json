{
	"name": "obsidian-confluence-root",
	"version": "5.5.2",
	"private": true,
	"workspaces": [
		"packages/lib",
		"packages/mermaid-electron-renderer",
		"packages/mermaid-puppeteer-renderer",
		"packages/cli",
		"packages/obsidian"
	],
	"type": "module",
	"scripts": {
		"prepare": "husky install",
		"predev-obsidian": "vp run build",
		"dev-obsidian": "vp run --parallel --filter @markdown-confluence/lib --filter @markdown-confluence/mermaid-electron-renderer --filter obsidian-confluence dev",
		"build": "vp run -r build",
		"check": "vp check && node scripts/check-descriptive-names.js",
		"fmt": "vp fmt --write",
		"fmt:check": "vp fmt --check",
		"lint": "vp lint --vitest-plugin --react-plugin . && node scripts/check-descriptive-names.js",
		"lint:names": "node scripts/check-descriptive-names.js",
		"mutation": "stryker run",
		"mutation:dry-run": "stryker run --dryRunOnly",
		"test": "vp test run"
	},
	"devDependencies": {
		"@effect-oxlint/effect-oxlint": "jsr:^0.2.0",
		"@effect/platform-node": "4.0.0-beta.70",
		"@effect/vitest": "4.0.0-beta.70",
		"@stryker-mutator/core": "9.6.1",
		"@stryker-mutator/typescript-checker": "9.6.1",
		"@types/node": "^25.9.0",
		"@vitest/runner": "4.1.5",
		"effect": "4.0.0-beta.70",
		"husky": "^9.1.7",
		"oxlint": "1.63.0",
		"tslib": "2.8.1",
		"typescript": "^6.0.3",
		"vite-plus": "^0.1.21",
		"vitest": "npm:@voidzero-dev/vite-plus-test@0.1.21"
	},
	"packageManager": "pnpm@11.1.2"
}
