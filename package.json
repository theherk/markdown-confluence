{
	"name": "obsidian-confluence-root",
	"version": "5.5.2",
	"private": true,
	"workspaces": [
		"packages/lib",
		"packages/mermaid-electron-renderer",
		"packages/mermaid-puppeteer-renderer",
		"packages/cli",
		"packages/obsidian"
	],
	"type": "module",
	"scripts": {
		"prepare": "husky install",
		"predev-obsidian": "vp run build",
		"dev-obsidian": "vp run --parallel --filter @markdown-confluence/lib --filter @markdown-confluence/mermaid-electron-renderer --filter obsidian-confluence dev",
		"build": "vp run -r build",
		"check": "vp check",
		"fmt": "vp fmt --write",
		"fmt:check": "vp fmt --check",
		"lint": "vp lint --vitest-plugin --react-plugin .",
		"test": "vp test run"
	},
	"devDependencies": {
		"@types/node": "^25.8.0",
		"husky": "^9.1.7",
		"tslib": "2.8.1",
		"typescript": "^6.0.3",
		"vite-plus": "^0.1.21"
	},
	"packageManager": "pnpm@11.1.2"
}
