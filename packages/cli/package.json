{
	"name": "@markdown-confluence/cli",
	"version": "5.5.2",
	"description": "This CLI allows you to publish your notes to Confluence",
	"keywords": [],
	"homepage": "https://github.com/markdown-confluence/markdown-confluence/tree/main/packages/cli",
	"bugs": {
		"url": "https://github.com/markdown-confluence/markdown-confluence/issues"
	},
	"license": "Apache 2.0",
	"author": "andymac4182",
	"repository": {
		"type": "git",
		"url": "https://github.com/markdown-confluence/markdown-confluence",
		"directory": "packages/cli"
	},
	"bin": "dist/index.js",
	"type": "module",
	"publishConfig": {
		"access": "public",
		"provenance": true,
		"registry": "https://registry.npmjs.org/"
	},
	"scripts": {
		"dev": "vp build --watch",
		"clidev": "vp run build && node ./dist/index.js",
		"build": "vp exec tsc --noEmit && vp build",
		"build:docker": "docker build -t markdown-confluence/markdown-confluence .",
		"fmt": "vp fmt --write \"src/**/*.{ts,tsx,js}\"",
		"fmt:check": "vp fmt --check \"src/**/*.{ts,tsx,js}\"",
		"lint": "vp lint src"
	},
	"dependencies": {
		"@effect/platform-node": "4.0.0-beta.68",
		"effect": "4.0.0-beta.70"
	},
	"devDependencies": {
		"@markdown-confluence/lib": "workspace:5.5.2",
		"@markdown-confluence/mermaid-puppeteer-renderer": "workspace:5.5.2",
		"boxen": "8.0.1",
		"chalk": "5.6.2",
		"confluence.js": "^2.1.0"
	},
	"bundleDependencies": true
}
